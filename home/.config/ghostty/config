# CURSOR
cursor-style = block
cursor-style-blink = false

# SPACING
adjust-cell-height = 2

# FONT
font-family = "Google Sans Code"
# font-family = "JetBrains Mono"
# font-family = "Monaco"
font-feature = "-calt"
font-feature = "-liga"
font-feature = "-dlig"
font-size = 18

# font-thicken = true
# 0 to 255, MacOS only
# font-thicken-strength = 150

# THEME
# theme = dark:Tokyonight Storm,light:Nvim Light
theme = dark:Catppuccin Frappe,light:Catppuccin Latte
# theme = Tokyonight Storm
# theme = Nvim Light
# theme = Builtin Solarized Dark

# KEYBOARD
# Enable Shift+Enter for AI tools
keybind = shift+enter=text:\x1b\r
